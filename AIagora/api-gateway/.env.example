# ── Server ───────────────────────────────────────────────────────────────────
GATEWAY_PORT=

# ── Redis (없어도 동작, 있으면 5분 캐싱 활성화) ──────────────────────────────
REDIS_URL=

# ── 수익형 API (없으면 mock 데이터 반환) ─────────────────────────────────────

# 쿠팡 파트너스
# 발급: https://partners.coupang.com → 개발자센터 → API 키 발급
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# 스카이스캐너 (RapidAPI 경유)
# 발급: https://rapidapi.com → "Skyscanner Flight Search" 구독
SKYSCANNER_API_KEY=

# 아고다 파트너 API
# 발급: https://partners.agoda.com (파트너 심사 필요)
AGODA_SITE_ID=
AGODA_API_KEY=

# 11번가 오픈API
# 발급: https://openapi.11st.co.kr
ELEVENST_APP_KEY=

# ── 무료 API (발급 즉시 사용 가능) ───────────────────────────────────────────

# 네이버 검색 API — 쇼핑·지역·뉴스
# 발급: https://developers.naver.com/apps → [애플리케이션 등록] → 검색 API 선택
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 카카오 REST API — 지역 검색·장소
# 발급: https://developers.kakao.com → 내 애플리케이션 → REST API 키 복사
KAKAO_REST_API_KEY=

# 기상청 단기예보 API
# 발급: https://data.go.kr → "기상청_단기예보" 검색 → 활용신청 → 인증키 복사
WEATHER_API_KEY=

# 한국은행 ECOS API — 환율 데이터
# 발급: https://ecos.bok.or.kr → API 서비스 → 인증키 신청
BOK_API_KEY=

# 공공데이터포털 범용 인증키
# 발급: https://data.go.kr → 마이페이지 → 인증키 확인
PUBLIC_DATA_KEY=

# ── k-skill 연동 API (선택) ───────────────────────────────────────────────────

# 서울 열린데이터광장 — 지하철 실시간 도착 (없으면 mock)
# 발급: https://data.seoul.go.kr → 서비스신청 → 인증키 발급
SEOUL_OPEN_API_KEY=

# 스위트트래커 배송조회 API — 택배사 통합 조회 (없으면 mock)
# 발급: https://info.sweettracker.co.kr → API 서비스 신청
SWEETTRACKER_API_KEY=

# ── public-apis-4Kr 연동 API ──────────────────────────────────────────────────

# 한국관광공사 TourAPI 4.0 — 관광지/숙박/음식점/축제 (없으면 PUBLIC_DATA_KEY 사용)
# 발급: https://api.visitkorea.or.kr → 서비스 신청 → 인증키 발급
TOURAPI_KEY=

# Open DART API — 상장사 공시/재무정보 (없으면 mock)
# 발급: https://opendart.fss.or.kr → API 사용 신청 (무료)
DART_API_KEY=

# 한국석유공사 OPINET — 주유소 가격 (없으면 mock)
# 발급: https://www.opinet.co.kr/user/custapi/custApiInfo.do → API 키 신청 (무료)
OPINET_API_KEY=
