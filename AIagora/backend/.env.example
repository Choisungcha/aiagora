# ── Server ───────────────────────────────────────────────────────────────────
PORT=
NODE_ENV=

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=

# ── Redis (없어도 동작, 있으면 블랙리스트/스테이킹 활성화) ─────────────────
REDIS_URL=

# ── PostgreSQL (없어도 동작, 있으면 협상 로그 저장) ──────────────────────────
DATABASE_URL=

# ── On-chain (Polygon Amoy Testnet) ──────────────────────────────────────────
POLYGON_AMOY_RPC=
POLYGON_AMOY_WS_RPC=
CHAIN_ID=

# 브리지 지갑 개인키 — 컨트랙트 배포 후 여기에 입력
# 발급: MetaMask 새 지갑 생성 → 개인키 복사
# 테스트 MATIC 충전: https://faucet.polygon.technology
BRIDGE_PRIVATE_KEY=

# 컨트랙트 주소 — blockchain/.env 세팅 후 배포하면 deployments.json 에 생성됨
AGENT_REGISTRY_ADDRESS=
DEAL_RECORD_ADDRESS=
REPUTATION_ADDRESS=
ESCROW_ADDRESS=
